<% layout("/layouts/boilerplate") %>

<h1>All Listings</h1>
<div class="row listings-row g-4">
    <% for(let listing of allListings){ %>
        <div class="col-lg-3 col-md-4 col-sm-6 col-12">
            <div class="card listing-card h-100">
                <a href="/listings/<%= listing._id %>">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.image.filename %>">
                    <div class="card-body">
                        <h3><%= listing.title %></h3>
                        <p class="card-text"><%= listing.description %></p>
                        <p class="mb-1">&#8377; <%= listing.price.toLocaleString('en-IN') %>/night</p>
                        <p class="mb-0 text-muted small"><%= listing.location %>, <%= listing.country %></p>
                    </div>
                </a>
            </div>
        </div>
    <% } %>
</div>
