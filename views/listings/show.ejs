<% layout("/layouts/boilerplate") %>

    <div class="card show-listing" style="width: 100%;">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.image.filename %>">
        <div class="card-body">
            <h5 class="card-title">
                <%= listing.title %>
            </h5>
            <p>By - <%= listing.owner.username %>
            </p>
            <p class="card-text">
                <%= listing.description %>
            </p>
            <p>&#8377;<%= (Number(listing.price) || 0).toLocaleString('en-IN') %>/night
                    <% if (listing.gstPercentage) { %>
                        <span class="text-muted small">(+ <%= listing.gstPercentage %>% GST)</span>
                        <% } %>
            </p>
            <% if (listing.category) { %>
                <p class="small text-capitalize text-muted">Category: <%= listing.category.replace(/-/g, ' ' ) %>
                </p>
                <% } %>
                    <p>
                        <%= listing.location %>, <%= listing.country %>
                    </p>
                    <% if(currentLoggedInUser && String(currentLoggedInUser._id)===String(listing.owner._id)){ %>
                        <a href="/listings/<%=listing._id%>/edit" class="btn btn-success">Edit Listing</a>
                        <a href="/listings/<%=listing._id%>/delete" class="btn btn-danger">Delete Listing</a>
                        <% }%>
        </div>
    </div>
    <!-- Review Form -->
    <% if(currentLoggedInUser){ %>
        <hr>
        <h4>Add Rating</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="rating" class="form-label">Rating</label>
                <fieldset class="starability-slot">
                    <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked
                        aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="rating" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="rating" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="rating" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="rating" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="rating" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
            </div>
            <div class="mb-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea class="form-control" id="comment" name="comment" rows="3" required></textarea>
                <div class="invalid-feedback">
                    Please provide a comment.
                </div>
            </div>
            <button type="submit" class="btn btn-outline-danger">Add Review</button>
        </form>
        <% } %>

            <!-- All reviews -->
            <hr>
            <div class="container my-5">
                <h4>All Reviews</h4>
                <div class="row">
                    <% if(listing.reviews.length==0){ %>
                        <p>No Reviews</p>
                        <% }else{ %>
                            <% for(let review of listing.reviews){ %>
                                <div class="card col-lg-3 col-md-4 col-sm-6 col-12 m-3 border border-danger"
                                    style="width: 18rem;">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-body-secondary">
                                            <%= review.comment %>
                                        </h6>
                                        <p class="starability-result" data-rating="<%= review.rating %>">
                                        </p>
                                        <p>By - @<%= review.owner.username %>
                                        </p>
                                        <a href="/listings/<%= listing._id %>/reviews/<%= review._id %>"
                                            class="btn btn-dark">Delete</a>
                                    </div>
                                </div>
                                <% }} %>
                </div>
            </div>